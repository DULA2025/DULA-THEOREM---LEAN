theorem heightPairing_symm {E : EllipticCurve ℚ} [HeightTheory E] (P Q : E.Point ℚ) : heightPairing P Q = heightPairing Q P := by
  -- By definition of height pairing, we have heightPairing P Q = (canonicalHeight (P + Q) - canonicalHeight P - canonicalHeight Q) / 2 and heightPairing Q P = (canonicalHeight (Q + P) - canonicalHeight Q - canonicalHeight P) / 2.
  simp [heightPairing];
  rw [ add_comm ] ; ring;

abbrev IsTorsion {E : EllipticCurve ℚ} (P : E.Point ℚ) : Prop := IsOfFinAddOrder P

theorem heightPairing_positive_definite {E : EllipticCurve ℚ} [StrongHeightTheory E] (P : E.Point ℚ) (h : ¬ IsTorsion P) : heightPairing P P > 0 := by
  -- By definition of $heightPairing$, we have $heightPairing P P = \frac{E.strongHeightTheory.canonicalHeight (P + P) - E.strongHeightTheory.canonicalHeight P - E.strongHeightTheory.canonicalHeight P}{2}$.
  unfold heightPairing;
  -- Since $P$ is not torsion, its canonical height is positive.
  have h_canonicalHeight_pos : (‹StrongHeightTheory E›.canonicalHeight P) > 0 := by
    by_contra h_neg;
    cases lt_or_eq_of_le ( le_of_not_gt h_neg ) <;> simp_all +decide;
    · exact not_lt_of_ge ( ‹StrongHeightTheory E›.canonicalHeight_nonneg P ) ‹_›;
    · rename_i h';
      apply h;
      obtain ⟨ n, hn ⟩ := ‹StrongHeightTheory E›.canonicalHeight_zero_iff_torsion P |>.1 h';
      exact isOfFinAddOrder_iff_nsmul_eq_zero.mpr ⟨ n, Nat.pos_of_ne_zero hn.1, hn.2 ⟩;
  have := ‹StrongHeightTheory E›.canonicalHeight_quadratic P 2;
  norm_num [ two_smul ] at * ; linarith

