structure EllipticCurve (K : Type) [Field K] where
  toWeierstrassCurve : WeierstrassCurve K

def EllipticCurve.Point {K : Type} [Field K] (E : EllipticCurve K) (L : Type) [Field L] [Algebra K L] : Type :=
  WeierstrassCurve.Projective.Point (E.toWeierstrassCurve.baseChange L).toProjective

def EllipticCurve.ofWeierstrass {K : Type} [Field K] (a1 a2 a3 a4 a6 : K) : EllipticCurve K :=
  ⟨WeierstrassCurve.mk a1 a2 a3 a4 a6⟩

instance (E : EllipticCurve ℚ) : AddCommGroup (E.Point ℚ) := by
  unfold EllipticCurve.Point
  infer_instance

class HeightTheory (E : EllipticCurve ℚ) where
  canonicalHeight : E.Point ℚ → ℝ
  canonicalHeight_quadratic : ∀ (P : E.Point ℚ) (n : ℤ), canonicalHeight (n • P) = (n ^ 2 : ℝ) * canonicalHeight P
  canonicalHeight_nonneg : ∀ (P : E.Point ℚ), canonicalHeight P ≥ 0
  canonicalHeight_zero_iff_torsion : ∀ (P : E.Point ℚ), canonicalHeight P = 0 ↔ (∃ (n : ℕ), n ≠ 0 ∧ n • P = 0)

def heightPairing {E : EllipticCurve ℚ} [HeightTheory E] (P Q : E.Point ℚ) : ℝ :=
  (HeightTheory.canonicalHeight (P + Q) - HeightTheory.canonicalHeight P - HeightTheory.canonicalHeight Q) / 2

class StrongHeightTheory (E : EllipticCurve ℚ) extends HeightTheory E where
  canonicalHeight_parallelogram : ∀ (P Q : E.Point ℚ), canonicalHeight (P + Q) + canonicalHeight (P - Q) = 2 * canonicalHeight P + 2 * canonicalHeight Q

